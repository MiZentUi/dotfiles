{
  "margin-top" : 10,
    "margin-left": 10,
    "margin-right": 10,
    "height" : 30,
    "modules-left": [
      "hyprland/window"
    ],
    "modules-center": [
      "hyprland/workspaces",
    ],
    "modules-right": [
    "pulseaudio",
    "network",
    "temperature",
    "cpu",
    "memory",
    "battery",
    "clock",
    ],
    "hyprland/window": {
      "format": "{}",
      "max-length": 50,
      "rewrite": {
        "": "MiZentUi"
      },
      "separate-outputs": true,
    },
    "hyprland/workspaces": {
      "format": "{icon}",
      "on-click": "activate",
      "format-icons": {
        "active": "¯®▒",
      },
      "sort-by-number": true,
      "persistent-workspaces": {
        "*": 3, // 5 workspaces by default on every monitor
        "HDMI-A-1": 3 // but only three on HDMI-A-1
      }
    },
    "clock": {
      "tooltip-format": "{:%d %B %Y}\n<tt><small>{calendar}</small></tt>",
      "format-alt": "{:%d-%m-%Y}",
      "interval": 1,
      "format": "{:%H:%M:%S}",
      "calendar": {
	"mode"          : "month",
	"mode-mon-col":   3,
	"on-scroll"     : 1,
        "on-click-right": "mode",
    	"format": {
	   "months":     "<span color='#990099'><b>{}</b></span>",
	   "weeks":	 "{:%U}",
	   "weekdays":   "<b>{}</b>",
	   "today":      "<span color='#ffa500'><b>{}</b></span>"
	}
      },
      "actions": {
	    "on-click-right": "mode",
	    "on-click-forward": "tz_up",
	    "on-click-backward": "tz_down",
	    "of-scroll-up": "shift_up",
	    "on-scroll-down": "shift_down"
      }
    },
    "cpu": {
      "format": "´Æ╝  {usage}%",
      "tooltip": false
    },
    "memory": {
      "format": "¯┐à  {}%"
    },
    "temperature": {
      "interval": 1,
      "critical-threshold": 80,
      "format": "{icon} {temperatureC}┬░C",
      "format-icons": ["´ïè", "´ïë", "´ïç"]
    },
    "battery": {
      "states": {
        "warning": 30,
        "critical": 10
      },
      "interval": 1,
      "format": "{icon}  {capacity}%",
      "format-full": "{icon}  {capacity}%",
      "format-charging": "¯║í  {capacity}%",
      "format-plugged": "´çª  {capacity}%",
      "format-alt": "{time} {icon}",
      "format-icons": ["´ëä", "´ëâ", "´ëé", "´ëü", "´ëÇ"]
    },
    "network": {
      "format-wifi": "´ç½  {signalStrength}%",
      "format-ethernet": "{cidr} ¯¢ä ",
      "tooltip-format": "{ifname} via {gwaddr} ¯¢ä",
      "format-linked": "{ifname} (No IP) ¯¢ä",
      "format-disconnected": " ÔÜá ",
      "format-alt": "{ifname}: {ipaddr}/{cidr}"
    },
    "pulseaudio": {
      "format": "{icon}  {volume}%",
      "format-bluetooth": "{volume}% {icon} ´èö {format_source}",
      "format-bluetooth-muted": "¯¼ñ  {icon} ´èö {format_source}",
      "format-muted": "¯¼ñ",
      "format-icons": {
        "headphone": "´ÇÑ",
        "hands-free": "¯╣Ö",
        "headset": "¯╣Ö",
        "phone": "´éò",
        "portable": "´éò",
        "car": "´å╣",
        "default": ["´Çª", "´Çº", "´Ç¿"]
      },
      "on-click": "pavucontrol"
    },
}
