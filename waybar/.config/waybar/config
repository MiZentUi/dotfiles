{
    "margin-top": 10,
    "margin-left": 10,
    "margin-right": 10,
    "height": 30,
    "modules-left": [
        "hyprland/window"
    ],
    "modules-center": [
        "hyprland/workspaces"
    ],
    "modules-right": [
        "tray",        
        "pulseaudio",
        "network",
        "temperature",
        "cpu",
        "memory",
        "battery",
        "clock"
    ],
    "hyprland/window": {
        "format": "{}",
        "max-length": 60,
        "rewrite": {
            "": "MiZentUi"
        },
        "separate-outputs": true
    },
    "hyprland/workspaces": {
        "format": "{icon}",
        "on-click": "activate",
        "format-icons": {
            "active": "о©±"
        },
        "sort-by-number": true,
        "persistent-workspaces": {
            "*": 3,
            "HDMI-A-1": 3
        }
    },
    "clock": {
        "tooltip-format": "{:%d %B %Y}\n<tt><small>{calendar}</small></tt>",
        "format-alt": "{:%d-%m-%Y}",
        "interval": 1,
        "format": "{:%H:%M:%S}",
        "calendar": {
            "mode": "month",
            "mode-mon-col": 3,
            "on-scroll": 1,
            "on-click-right": "mode",
            "format": {
                "months": "<span color='#990099'><b>{}</b></span>",
                "weeks": "{:%U}",
                "weekdays": "<b>{}</b>",
                "today": "<span color='#ffa500'><b>{}</b></span>"
            }
        },
        "actions": {
            "on-click-right": "mode",
            "on-click-forward": "tz_up",
            "on-click-backward": "tz_down",
            "of-scroll-up": "shift_up",
            "on-scroll-down": "shift_down"
        }
    },
    "cpu": {
        "format": "пТЉ  {usage}%",
        "tooltip": false
    },
    "memory": {
        "format": "оњЕ  {}%"
    },
    "temperature": {
        "interval": 1,
        "critical-threshold": 80,
        "format": "{icon} {temperatureC}¬∞C",
        "format-icons": [
            "пЛК",
            "пЛЙ",
            "пЛЗ"
        ]
    },
    "battery": {
        "states": {
            "warning": 30,
            "critical": 15
        },
        "interval": 1,
        "format": "{icon}  {capacity}%",
        "format-full": "{icon}  {capacity}%",
        "format-charging": "оЇ°  {capacity}%",
        "format-plugged": "пЗ¶  {capacity}%",
        "format-alt": "{time} {icon}",
        "format-icons": [
            "пЙД",
            "пЙГ",
            "пЙВ",
            "пЙБ",
            "пЙА"
        ]
    },
    "network": {
        "format-wifi": "пЗЂ  {signalStrength}%",
        "format-ethernet": "{cidr} ољД ",
        "tooltip-format": "{ifname} via {gwaddr} ољД",
        "format-linked": "{ifname} (No IP) ољД",
        "format-disconnected": " вЪ† ",
        "format-alt": "{ifname}: {ipaddr}/{cidr}"
    },
    "pulseaudio": {
