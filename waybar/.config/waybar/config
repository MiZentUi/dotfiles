        "format-bluetooth": "{volume}% {icon} пКФ {format_source}",
        "format-bluetooth-muted": "ођ§  {icon} пКФ {format_source}",
        "format-muted": "ођ§",
        "format-icons": {
            "headphone": "пА•",
            "hands-free": "оєЩ",
            "headset": "оєЩ",
            "phone": "пВХ",
            "portable": "пВХ",
            "car": "пЖє",
            "default": [
